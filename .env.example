# MongoDB connection to the Architect database
# For local dev, point to whatever DB_URL the architect-backend uses
DB_URL=mongodb://localhost:27017
DB_NAME=architect

# OpenAI API key for scoring
OPENAI_API_KEY=sk-...

# Model used for scoring. gpt-4.1 is strongly recommended for rubric reasoning.
OPENAI_MODEL=gpt-4.1

# Port for the hackathon eval backend (separate from architect-backend on 8002)
PORT=8010
